{
  "name": "web-discovery-agent",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered Discovery & Competitor Intelligence System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @discovery/api dev\" \"pnpm --filter @discovery/web dev\"",
    "dev:api": "pnpm --filter @discovery/api dev",
    "dev:web": "pnpm --filter @discovery/web dev",
    "build": "pnpm -r build --if-present",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/database/prisma/schema.prisma",
    "db:seed": "ts-node -r tsconfig-paths/register packages/database/src/seed.ts",
    "crawl": "pnpm --filter @discovery/api crawl",
    "demo": "pnpm --filter @discovery/api demo",
    "install:playwright": "pnpm exec playwright install chromium",
    "setup": "pnpm install && pnpm run db:push && pnpm run db:seed && pnpm run install:playwright"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0"
  }
}

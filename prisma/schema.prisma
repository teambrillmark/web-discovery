generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Competitor {
  id               String           @id @default(uuid())
  normalizedDomain String           @unique
  rawInput         String
  status           CompetitorStatus @default(DISCOVERED)
  discoverySource  String
  // Tracks which generation of the discovery pipeline found this competitor.
  // Increment when making breaking changes to extraction/query logic so stale
  // intelligence can be identified, filtered, or reset without a full truncation.
  // Generation 1 = pre-competitive-intent pipeline (flat service discovery).
  // Generation 2 = competitive-intent pipeline (primaryCompetitiveIdentity-anchored).
  pipelineVersion  Int              @default(2)
  discoveredAt     DateTime         @default(now())
  lastDiscoveredAt DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  discoveries      Discovery[]

  @@index([normalizedDomain])
  @@index([status])
  @@index([pipelineVersion])
  @@map("competitors")
}

model Discovery {
  id              String     @id @default(uuid())
  competitorId    String
  queryId         String
  source          String
  discoveryMethod String
  originalValue   String
  discoveredAt    DateTime
  createdAt       DateTime   @default(now())

  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@index([queryId])
  @@index([source])
  @@map("discoveries")
}

// Rejected candidates are intelligence too.
// Knowing a domain is NOT a competitor prevents reprocessing it on future runs
// and allows analysis of which discovery providers generate the most noise.
model RejectedCandidate {
  id              String   @id @default(uuid())
  domain          String
  queryId         String
  rejectionReason String
  // "rule-filter" = cheap rule caught it; "ai-validation" = AI determined irrelevance
  rejectionStage  String
  // Entity type classification: agency, saas, tool, community, job-board, etc.
  classification  String
  // Relevance determination from AI stage (null for rule-filter rejections)
  relevance       String?
  confidence      Float
  // Which discovery provider surfaced this candidate
  provider        String?
  rejectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([queryId])
  @@index([domain])
  @@index([rejectionReason])
  @@map("rejected_candidates")
}

// Profiles extracted for each discovered competitor, scoped to a discovery run.
// AI extracts the profile; deterministic code scores and ranks.
// Not FK-linked to Competitor so profiling never blocks discovery persistence.
model CompetitorProfile {
  id                         String   @id @default(uuid())
  domain                     String
  queryId                    String
  companyType                String?
  industry                   String?
  niche                      String?
  primaryCompetitiveIdentity String?
  primarySpecialties         Json     @default("[]")
  coreServices               Json     @default("[]")
  targetAudience             Json     @default("[]")
  positioning                String?
  aiConfidence               String   @default("low")
  relevanceScore             Float    @default(0)
  scoreConfidence            String   @default("low")
  matchedSignals             Json     @default("{}")
  scoringReasoning           Json     @default("[]")
  // Authoritative normalized taxonomy — persisted so downstream layers
  // (API, UI, analytics) all consume the same classification without recomputing.
  businessModel              String?
  businessModelConfidence    Json     @default("{}")
  createdAt                  DateTime @default(now())

  @@unique([domain, queryId])
  @@index([domain])
  @@index([queryId])
  @@index([relevanceScore])
  @@map("competitor_profiles")
}

enum CompetitorStatus {
  DISCOVERED
  VALIDATED_PASS
  VALIDATED_FAIL
}

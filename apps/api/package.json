{
  "name": "@discovery/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti :3001 | xargs kill -9 2>/dev/null; ts-node-dev --respawn --transpile-only --require tsconfig-paths/register --project tsconfig.json src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "crawl": "ts-node -r tsconfig-paths/register --project tsconfig.json src/scripts/crawl.ts",
    "demo": "ts-node -r tsconfig-paths/register --project tsconfig.json src/scripts/demo.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@discovery/crawler": "workspace:*",
    "@discovery/database": "workspace:*",
    "@discovery/extraction": "workspace:*",
    "@discovery/ranking": "workspace:*",
    "@discovery/shared": "workspace:*",
    "@discovery/validation": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "json2csv": "^6.0.0-alpha.2",
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}

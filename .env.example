# -------------------------------------------------------
# Required: PostgreSQL connection string (Prisma)
# -------------------------------------------------------
DATABASE_URL=postgres://c9090a87d384c45a14d6b91f6568c4e0d1c99d356f196a7e95c69a8aba4ac87d:sk_CRTUJqO1ubG6a7DB75nI6@db.prisma.io:5432/postgres?sslmode=require

# -------------------------------------------------------
# Required for AI Discovery + Context Extraction: Groq API key
# Get yours at: https://console.groq.com
# Without this:
#   - Discovery module runs in stub-only mode (no AI competitors returned)
#   - Context Extractor returns 503 (AI analysis unavailable)
# -------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here

# -------------------------------------------------------
# Optional: log verbosity (trace | debug | info | warn | error | fatal)
# Default: info
# -------------------------------------------------------
LOG_LEVEL=info

# -------------------------------------------------------
# Optional: Groq model override
# Default: llama-3.3-70b-versatile
# -------------------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile
